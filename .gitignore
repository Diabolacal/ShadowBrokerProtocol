# ─────────────────────────────────────────────────────────────────────────
# Shadow Broker Protocol .gitignore
# ─────────────────────────────────────────────────────────────────────────

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Editor
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/prompts/
!.vscode/mcp.json

# Environment & secrets
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# Node.js
node_modules/
dist/
build/
*.tgz
.npm
.eslintcache
*.tsbuildinfo

# Sui Move build artifacts
contracts/*/build/
contracts/*/.coverage_map.mvcov
contracts/*/.trace

# Branding reference files (not part of the app, excluded from tsconfig)
apps/web/src/branding/

# Python (if applicable)
__pycache__/
*.pyc
*.pyo

# Working memory (agent ephemeral files — not committed)
docs/working_memory/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Local notes (may contain addresses, keys, sensitive local context)
notes/

# Temporary files
tmp_*
temp_*
*.tmp
*.bak
*.swp
*~
